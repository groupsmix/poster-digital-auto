# AI Product Factory - Production Environment Variables
# Copy to /opt/ai-product-factory/.env and fill in your API keys

# Database path (persistent storage on Oracle Cloud)
DATABASE_PATH=/data/app.db

# Google AI Studio (Gemini) - REQUIRED
# Get your key at: https://ai.google.dev
GEMINI_API_KEY=

# Groq - Recommended
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# Cloudflare Workers AI - Optional
# Get from: https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cerebras - Optional
# Get from: https://cerebras.ai
CEREBRAS_API_KEY=

# Mistral AI - Optional
# Get from: https://console.mistral.ai
MISTRAL_API_KEY=

# HuggingFace - Optional (for image generation fallback)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=
