# AI Product Factory - API Keys
# All services are free tier, no credit card required

# Google AI Studio (Gemini) - https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Groq - https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Cloudflare Workers AI - https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cerebras - https://cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Mistral AI - https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Auto-Posting API Keys (optional) ──────────────────────────────

# Telegram Bot - https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_or_chat_id

# Tumblr - https://www.tumblr.com/oauth/apps
TUMBLR_API_KEY=your_tumblr_consumer_key
TUMBLR_ACCESS_TOKEN=your_tumblr_access_token
TUMBLR_BLOG_NAME=yourblog.tumblr.com

# Pinterest - https://developers.pinterest.com
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
PINTEREST_BOARD_ID=your_board_id
